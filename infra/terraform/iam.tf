resource "aws_iam_role_policy" "ecs_events_run_task" {
  name = "${local.name_prefix}-ecs-events-run-task"
  role = aws_iam_role.ecs_events.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "ecs:RunTask"
        ]
        Resource = [
          aws_ecs_task_definition.user_migrate.arn,
          aws_ecs_task_definition.vehicle_migrate.arn
        ]
      },
      {
        Effect = "Allow"
        Action = [
          "iam:PassRole"
        ]
        Resource = [
          aws_iam_role.ecs_execution.arn,
          aws_iam_role.ecs_task.arn
        ]
      }
    ]
  })
}
