aws_region  = "eu-central-1"
project_name = "vsp"
environment  = "prod"
image_tag    = "latest"

# Optional per-service image tags. If omitted, each service uses image_tag.
# frontend_image_tag        = "latest"
# user_service_image_tag    = "latest"
# vehicle_service_image_tag = "latest"

db_backup_retention_days = 1
db_deletion_protection   = false

mq_instance_type = "mq.m7g.medium"

# Leave empty on the first apply. After `terraform apply`, copy output `frontend_url` here and apply again.
frontend_url = ""

# Optional sizing overrides
# ecs_cpu      = "512"
# ecs_memory   = "1024"
# ecs_min_tasks = 1
# ecs_max_tasks = 4
