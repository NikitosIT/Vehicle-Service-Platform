{
  "name": "vehicle-service-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "docker:dev:up": "docker compose --env-file .env.dev -f docker-compose.dev.yml up -d --build",
    "docker:dev:down": "docker compose --env-file .env.dev -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose --env-file .env.dev -f docker-compose.dev.yml logs -f",
    "docker:prod:up": "docker compose --env-file .env.prod -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose --env-file .env.prod -f docker-compose.prod.yml down",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:generate:user": "npm run db:generate -w user-service",
    "db:generate:vehicle": "npm run db:generate -w vehicle-service",
    "db:migrate:dev:user": "npm run db:migrate:dev -w user-service",
    "db:migrate:dev:vehicle": "npm run db:migrate:dev -w vehicle-service",
    "db:migrate:deploy:user": "npm run db:migrate:deploy -w user-service",
    "db:migrate:deploy:vehicle": "npm run db:migrate:deploy -w vehicle-service",
    "db:migrate:deploy": "npm run db:migrate:deploy:user && npm run db:migrate:deploy:vehicle",
    "db:migrate:reset:user": "npm run db:migrate:reset -w user-service",
    "db:migrate:reset:vehicle": "npm run db:migrate:reset -w vehicle-service",
    "db:push:user": "npm run db:push -w user-service",
    "db:push:vehicle": "npm run db:push -w vehicle-service",
    "db:studio:user": "npm run db:studio -w user-service",
    "db:studio:vehicle": "npm run db:studio -w vehicle-service",
    "db:seed:user": "npm run db:seed -w user-service",
    "db:seed:vehicle": "npm run db:seed -w vehicle-service",
    "db:seed": "npm run db:seed:user && npm run db:seed:vehicle"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/microservices": "^11.1.26",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "nodemon": "^3.1.10",
    "turbo": "^2.5.4",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.9.0"
}
