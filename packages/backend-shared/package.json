{
  "name": "@vsp/backend-shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./auth-session": {
      "types": "./dist/auth-session/index.d.ts",
      "default": "./dist/auth-session/index.js"
    },
    "./paginate": {
      "types": "./dist/paginate/index.d.ts",
      "default": "./dist/paginate/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "default": "./dist/logger/index.js"
    },
    "./filters": {
      "types": "./dist/filters/index.d.ts",
      "default": "./dist/filters/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:ci": "eslint \"src/**/*.ts\"",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express-session": "^1.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0"
  }
}
